---
import { navLinks, site } from '../data/site';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-cream/90 backdrop-blur-md border-b border-cream-dark/60">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
    <a
      href="/"
      class="font-script text-2xl text-terracotta hover:text-terracotta-light transition-colors"
    >
      {site.name}
    </a>

    <ul class="hidden lg:flex items-center gap-6">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'text-sm font-semibold uppercase tracking-wider transition-colors',
                isActive(link.href)
                  ? 'text-terracotta'
                  : 'text-charcoal-light hover:text-terracotta',
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href={site.phoneHref}
          class="inline-flex items-center px-5 py-2 rounded-full bg-terracotta text-white text-sm font-semibold hover:bg-terracotta-light transition-colors"
        >
          {site.phone}
        </a>
      </li>
    </ul>

    <button
      type="button"
      id="mobile-menu-open"
      class="lg:hidden p-2 text-charcoal hover:text-terracotta transition-colors"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="4" x2="20" y1="12" y2="12" /><line x1="4" x2="20" y1="6" y2="6" /><line x1="4" x2="20" y1="18" y2="18" />
      </svg>
    </button>
  </div>
</nav>

<div
  id="mobile-menu"
  class="mobile-menu lg:hidden"
  hidden
  role="dialog"
  aria-modal="true"
  aria-label="Menu de navigation"
  aria-hidden="true"
>
  <button
    type="button"
    id="mobile-menu-backdrop"
    class="mobile-menu__backdrop"
    aria-label="Fermer le menu"
  ></button>

  <div class="mobile-menu__panel">
    <div class="flex items-center justify-between px-4 sm:px-6 h-16 border-b border-cream-dark/60 shrink-0">
      <a href="/" class="font-script text-2xl text-terracotta mobile-menu__link">
        {site.name}
      </a>
      <button
        type="button"
        id="mobile-menu-close"
        class="p-2 rounded-full text-charcoal hover:text-terracotta hover:bg-cream-dark/60 transition-colors"
        aria-label="Fermer le menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18" /><path d="m6 6 12 12" />
        </svg>
      </button>
    </div>

    <div class="flex-1 flex flex-col justify-center px-6 sm:px-10 py-8 overflow-y-auto">
      <p class="text-xs font-bold uppercase tracking-[0.3em] text-terracotta mb-8">Navigation</p>
      <ul class="space-y-2">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'mobile-menu__link block py-3 text-2xl sm:text-3xl font-semibold tracking-wide transition-colors',
                  isActive(link.href)
                    ? 'text-terracotta'
                    : 'text-charcoal hover:text-terracotta',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="px-6 sm:px-10 pb-10 pt-4 border-t border-cream-dark/60 shrink-0">
      <a
        href={site.phoneHref}
        class="mobile-menu__link flex items-center justify-center gap-3 w-full px-6 py-4 rounded-full bg-terracotta text-white font-semibold hover:bg-terracotta-light transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        {site.phone}
      </a>
      <p class="text-center text-sm text-charcoal-light mt-4">{site.tagline}</p>
    </div>
  </div>
</div>

<script src="/js/mobile-nav.js" defer></script>

<style>
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 60;
  }

  .mobile-menu__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(61 61 61 / 0.4);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 300ms ease-out;
  }

  .mobile-menu__panel {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    background: #f5f0e8;
    opacity: 0;
    transform: translateY(1.5rem);
    transition: all 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mobile-menu.is-visible .mobile-menu__backdrop {
    opacity: 1;
  }

  .mobile-menu.is-visible .mobile-menu__panel {
    opacity: 1;
    transform: translateY(0);
  }

  :global(body.mobile-menu-open) {
    overflow: hidden;
  }
</style>

---
import { site } from '../data/site';
import { FORM_LIMITS } from '../lib/security/form';
---

<div id="contact-form-root">
  <form id="contact-form" class="space-y-4" novalidate>
    <div
      class="absolute left-[-9999px] top-auto h-px w-px overflow-hidden"
      aria-hidden="true"
    >
      <label for="company">Ne pas remplir</label>
      <input type="text" id="company" name="company" tabindex="-1" autocomplete="off" />
    </div>

    <div id="contact-form-error" class="hidden flex items-start gap-2 rounded-xl border border-terracotta/30 bg-terracotta/10 px-4 py-3 text-sm text-charcoal" role="alert">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mt-0.5 shrink-0 text-terracotta" aria-hidden="true">
        <path d="M12 9v4" /><path d="M12 17h.01" /><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
      </svg>
      <p id="contact-form-error-text"></p>
    </div>

    <div>
      <label for="name" class="block text-sm font-semibold text-charcoal mb-1">Votre nom</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        minlength="2"
        maxlength={FORM_LIMITS.nameMaxLength}
        autocomplete="name"
        spellcheck="false"
        class="w-full px-4 py-3 rounded-xl border border-cream-dark bg-white/80 text-charcoal placeholder:text-charcoal-light/50 focus:outline-none focus:ring-2 focus:ring-terracotta/40 transition-shadow"
        placeholder="Prénom et nom"
      />
    </div>

    <div>
      <label for="message" class="block text-sm font-semibold text-charcoal mb-1">Votre message</label>
      <textarea
        id="message"
        name="message"
        required
        minlength="10"
        maxlength={FORM_LIMITS.messageMaxLength}
        rows={4}
        autocomplete="off"
        class="w-full px-4 py-3 rounded-xl border border-cream-dark bg-white/80 text-charcoal placeholder:text-charcoal-light/50 focus:outline-none focus:ring-2 focus:ring-terracotta/40 transition-shadow resize-none"
        placeholder="Décrivez vos besoins..."
      ></textarea>
      <p class="mt-1 text-xs text-charcoal-light">Maximum {FORM_LIMITS.messageMaxLength} caractères.</p>
    </div>

    <button
      type="submit"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-terracotta text-white font-semibold hover:bg-terracotta-light transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m22 2-7 20-4-9-9-4Z" /><path d="M22 2 11 13" />
      </svg>
      Envoyer un message
    </button>
  </form>

  <div id="contact-form-success" class="hidden flex-col items-center gap-3 py-8 text-center">
    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-sage" aria-hidden="true">
      <path d="M20 6 9 17l-5-5" />
    </svg>
    <p class="font-semibold text-charcoal">Votre client mail va s&apos;ouvrir.</p>
    <p class="text-sm text-charcoal-light">
      Si rien ne s&apos;ouvre, écrivez directement à{' '}
      <a href={site.emailHref} class="text-terracotta underline">{site.email}</a>
    </p>
    <button
      type="button"
      id="contact-form-reset"
      class="mt-2 text-sm text-terracotta hover:underline"
    >
      Envoyer un autre message
    </button>
  </div>
</div>

<script type="module" src="/js/contact-form.js"></script>

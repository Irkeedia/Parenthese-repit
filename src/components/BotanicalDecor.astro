---
interface Props {
  class?: string;
  variant?: 'left' | 'right' | 'corner';
}

const { class: className = '', variant = 'left' } = Astro.props;
---

<svg
  class:list={['pointer-events-none select-none text-sage', className]}
  viewBox="0 0 120 160"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  {
    variant === 'right' ? (
      <>
        <path
          d="M90 20 C70 40, 60 80, 75 120 C80 135, 95 145, 105 150"
          stroke="currentColor"
          stroke-width="1.5"
          fill="none"
          opacity="0.7"
        />
        <ellipse cx="62" cy="55" rx="18" ry="8" transform="rotate(-35 62 55)" stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.6" />
        <ellipse cx="78" cy="85" rx="16" ry="7" transform="rotate(-20 78 85)" stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.5" />
        <ellipse cx="88" cy="115" rx="14" ry="6" transform="rotate(-10 88 115)" stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.4" />
      </>
    ) : variant === 'corner' ? (
      <>
        <path d="M10 140 C30 120, 50 90, 40 50" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.5" />
        <ellipse cx="28" cy="110" rx="12" ry="5" transform="rotate(40 28 110)" stroke="currentColor" stroke-width="1" fill="none" opacity="0.4" />
        <ellipse cx="38" cy="75" rx="10" ry="4" transform="rotate(25 38 75)" stroke="currentColor" stroke-width="1" fill="none" opacity="0.35" />
      </>
    ) : (
      <>
        <path
          d="M30 20 C50 40, 60 80, 45 120 C40 135, 25 145, 15 150"
          stroke="currentColor"
          stroke-width="1.5"
          fill="none"
          opacity="0.7"
        />
        <ellipse cx="58" cy="55" rx="18" ry="8" transform="rotate(35 58 55)" stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.6" />
        <ellipse cx="42" cy="85" rx="16" ry="7" transform="rotate(20 42 85)" stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.5" />
        <ellipse cx="32" cy="115" rx="14" ry="6" transform="rotate(10 32 115)" stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.4" />
      </>
    )
  }
</svg>

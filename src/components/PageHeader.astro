---
import BotanicalDecor from './BotanicalDecor.astro';

interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="relative pt-28 pb-12 md:pt-36 md:pb-16 overflow-hidden bg-cream-dark/30">
  <BotanicalDecor variant="left" class="absolute top-24 left-0 w-20 md:w-28 opacity-40" />
  <BotanicalDecor variant="right" class="absolute bottom-0 right-0 w-24 opacity-30" />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">
    <p class="text-sm font-bold uppercase tracking-[0.25em] text-terracotta mb-3">Parenthèse Répit</p>
    <h1 class="font-script text-4xl sm:text-5xl md:text-6xl text-terracotta mb-4">{title}</h1>
    {subtitle && (
      <p class="text-lg md:text-xl text-charcoal-light max-w-3xl leading-relaxed">{subtitle}</p>
    )}
    <div class="w-16 h-0.5 bg-terracotta mt-6"></div>
  </div>
</section>

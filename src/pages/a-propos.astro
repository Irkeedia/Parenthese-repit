---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import StockImage from '../components/StockImage.astro';
import { site } from '../data/site';
import { images } from '../data/images';
---

<BaseLayout
  title="À propos — Parenthèse Répit"
  description="Découvrez le parcours d'Audrey Mas, accompagnante éducative et sociale diplômée, et l'approche de Parenthèse Répit."
  currentPath="/a-propos"
>
  <PageHeader
    title="À propos de moi"
    subtitle="Accompagnante Éducative et Sociale diplômée, je mets mon expertise au service des familles."
  />

  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <StockImage
          src={images.about.src}
          alt={images.about.alt}
          aspect="portrait"
          rounded="2xl"
        />

        <div class="space-y-6 text-charcoal-light leading-relaxed">
          {
            site.presentation.map((paragraph) => (
              <p>{paragraph}</p>
            ))
          }
        </div>
      </div>

      <div class="mt-12 bg-cream-dark/50 rounded-2xl p-8 border border-sage/20 max-w-2xl">
        <h2 class="font-semibold text-charcoal text-xl mb-6">Mes valeurs</h2>
        <ul class="space-y-4">
          {
            site.values.map((value) => (
              <li class="flex items-center gap-3">
                <span class="w-10 h-10 rounded-full bg-terracotta/10 flex items-center justify-center text-terracotta">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                </span>
                <span class="font-semibold text-charcoal">{value}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-cream-dark/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="font-script text-4xl text-terracotta mb-10 text-center">Pourquoi faire appel à Parenthèse Répit ?</h2>
      <ul class="grid sm:grid-cols-2 md:grid-cols-3 gap-4 max-w-4xl mx-auto">
        {
          site.whyChoose.map((reason) => (
            <li class="flex gap-3 bg-cream rounded-2xl p-5 border border-cream-dark/50 text-charcoal-light text-sm">
              <span class="text-sage flex-shrink-0">•</span>
              {reason}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-10">
        <div>
          <h2 class="font-semibold text-charcoal text-xl mb-4">Pour quels profils ?</h2>
          <ul class="space-y-3 text-charcoal-light">
            {
              site.profiles.map((profile) => (
                <li class="flex gap-2">
                  <span class="text-sage">•</span>
                  {profile}
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h2 class="font-semibold text-charcoal text-xl mb-4">Zone d'intervention</h2>
          <p class="text-charcoal-light leading-relaxed mb-4">
            J'interviens à domicile sur l'ensemble du secteur <strong class="text-charcoal">Narbonne – Béziers</strong>
            et les communes alentours : villages, hameaux et quartiers périphériques inclus.
          </p>
          <p class="text-sm text-charcoal-light">
            Vous habitez un peu plus loin ? Contactez-moi : nous verrons ensemble si une intervention
            est possible.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-20 bg-cream-dark/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="font-script text-4xl text-terracotta mb-10 text-center">Comment se déroule l'accompagnement ?</h2>
      <ol class="space-y-6 max-w-2xl mx-auto">
        {
          site.processSteps.map((step, index) => (
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-terracotta text-white flex items-center justify-center text-sm font-bold">
                {index + 1}
              </span>
              <p class="font-semibold text-charcoal pt-1">{step}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-semibold text-charcoal text-xl mb-6">Disponibilités</h2>
      <ul class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
        {
          site.availabilities.map((slot) => (
            <li class="px-5 py-2 rounded-full bg-cream border border-cream-dark/50 text-sm text-charcoal-light">
              {slot}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="py-12 bg-charcoal text-cream">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="font-script text-3xl text-terracotta-light mb-4">{site.closingTagline}</p>
      <p class="text-cream/70 mb-6">{site.credential}</p>
      <a href="/contact" class="inline-flex items-center px-6 py-3 rounded-full bg-terracotta text-white font-semibold hover:bg-terracotta-light transition-colors">
        Me contacter
      </a>
    </div>
  </section>
</BaseLayout>

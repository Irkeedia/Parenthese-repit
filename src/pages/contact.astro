---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactForm from '../components/ContactForm.astro';
import StockImage from '../components/StockImage.astro';
import { site } from '../data/site';
import { images } from '../data/images';
---

<BaseLayout
  title="Contact — Parenthèse Répit"
  description="Contactez Audrey pour un accompagnement bienveillant à domicile entre Narbonne et Béziers."
  currentPath="/contact"
>
  <PageHeader
    title="Contactez-moi"
    subtitle="Écoute, bienveillance, patience et respect sont au cœur de mon accompagnement."
  />

  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <StockImage
        src={images.contact.src}
        alt={images.contact.alt}
        aspect="wide"
        rounded="2xl"
        class="mb-12"
      />

      <div class="grid md:grid-cols-2 gap-10 md:gap-16">
        <div class="space-y-6">
          <p class="text-charcoal-light leading-relaxed">
            Vous avez une question, un besoin de répit ou souhaitez en savoir plus sur mes services ?
            N'hésitez pas à me contacter. Je vous réponds dans les meilleurs délais.
          </p>

          <a
            href={site.phoneHref}
            class="flex items-center gap-4 p-5 rounded-2xl bg-cream border border-cream-dark/50 hover:border-terracotta/30 hover:shadow-md transition-all group"
          >
            <div class="w-12 h-12 rounded-xl bg-terracotta/10 flex items-center justify-center text-terracotta group-hover:bg-terracotta/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-charcoal-light">Téléphone</p>
              <p class="font-semibold text-charcoal text-lg">{site.phone}</p>
            </div>
          </a>

          <a
            href={site.emailHref}
            class="flex items-center gap-4 p-5 rounded-2xl bg-cream border border-cream-dark/50 hover:border-terracotta/30 hover:shadow-md transition-all group"
          >
            <div class="w-12 h-12 rounded-xl bg-terracotta/10 flex items-center justify-center text-terracotta group-hover:bg-terracotta/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-charcoal-light">Email</p>
              <p class="font-semibold text-charcoal text-lg break-all">{site.email}</p>
            </div>
          </a>

          <div class="bg-cream-dark/50 rounded-2xl p-6 border border-sage/20">
            <h3 class="font-semibold text-charcoal mb-2">Zone d'intervention</h3>
            <p class="text-charcoal-light">{site.zone}</p>
          </div>

          <div class="bg-terracotta/10 rounded-2xl p-6 border border-terracotta/20">
            <p class="text-sm text-charcoal-light">
              <strong class="text-charcoal">Horaires de contact :</strong> du lundi au vendredi,
              de 9 h à 19 h. Je fais mon possible pour répondre rapidement aux messages laissés
              en dehors de ces créneaux.
            </p>
          </div>
        </div>

        <div class="bg-cream rounded-2xl p-6 md:p-8 border border-cream-dark/50 shadow-sm">
          <h3 class="font-semibold text-charcoal mb-4">Envoyez-moi un message</h3>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

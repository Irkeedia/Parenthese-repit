---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import LegalSection from '../components/LegalSection.astro';
import { site } from '../data/site';
import { imageCredits } from '../data/images';

const { legal } = site;
---

<BaseLayout
  title="Mentions légales — Parenthèse Répit"
  description="Mentions légales, propriété intellectuelle et protection des données personnelles du site Parenthèse Répit."
  currentPath="/mentions-legales"
>
  <PageHeader
    title="Mentions légales"
    subtitle="Informations légales relatives au site et à la protection de vos données."
  />

  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <p class="text-sm text-charcoal-light mb-10">
        Conformément aux dispositions des articles 6-III et 19 de la loi n° 2004-575 du 21 juin 2004
        pour la confiance dans l'économie numérique (LCEN), les présentes mentions légales sont
        portées à la connaissance des utilisateurs du site {site.name}, accessible sur le domaine{' '}
        <a href={legal.domainUrl} class="text-terracotta hover:underline" target="_blank" rel="noopener noreferrer">{legal.domain}</a>.
      </p>

      <LegalSection title="1. Éditeur du site">
        <p>
          Le site <strong class="text-charcoal">{site.name}</strong> est édité par :
        </p>
        <ul class="list-none space-y-1 pl-0">
          <li><strong class="text-charcoal">{legal.editor.name}</strong></li>
          <li>Géré par : {legal.editor.manager}</li>
          <li>
            Site web :{' '}
            <a href={legal.editor.website} class="text-terracotta hover:underline" target="_blank" rel="noopener noreferrer">
              {legal.domain}
            </a>
          </li>
          <li>
            Email :{' '}
            <a href={legal.editor.emailHref} class="text-terracotta hover:underline">{legal.editor.email}</a>
          </li>
        </ul>
      </LegalSection>

      <LegalSection title="2. Professionnelle présentée">
        <p>
          Le site présente l'activité de <strong class="text-charcoal">{legal.professional.businessName}</strong>,
          exercée par <strong class="text-charcoal">{legal.professional.name}</strong> :
        </p>
        <ul class="list-none space-y-1 pl-0">
          <li>{legal.professional.status}</li>
          <li>Adresse : {legal.professional.address}</li>
          <li>SIRET : {legal.professional.siret}</li>
          <li>Téléphone : <a href={site.phoneHref} class="text-terracotta hover:underline">{site.phone}</a></li>
          <li>Email : <a href={site.emailHref} class="text-terracotta hover:underline">{site.email}</a></li>
        </ul>
        <p>Zone d'intervention : {site.zone}.</p>
      </LegalSection>

      <LegalSection title="3. Directeur de la publication">
        <p>
          Le directeur de la publication est <strong class="text-charcoal">{legal.publicationDirector}</strong>,
          en qualité de responsable d'{legal.editor.name}, joignable à{' '}
          <a href={legal.editor.emailHref} class="text-terracotta hover:underline">{legal.editor.email}</a>.
        </p>
      </LegalSection>

      <LegalSection title="4. Hébergement">
        <p>Le site est hébergé par :</p>
        <ul class="list-none space-y-1 pl-0">
          <li><strong class="text-charcoal">{legal.host.name}</strong></li>
          <li>{legal.host.address}</li>
          <li>
            Site web :{' '}
            <a href={legal.host.website} class="text-terracotta hover:underline" target="_blank" rel="noopener noreferrer">
              {legal.domain}
            </a>
          </li>
        </ul>
      </LegalSection>

      <LegalSection title="5. Propriété intellectuelle">
        <p>
          L'ensemble du contenu éditorial relatif à l'activité {site.name} (textes, descriptions de
          services) est la propriété de {legal.professional.name}, sauf mention contraire.
        </p>
        <p>
          La conception, la structure et le développement du site sont réalisés par {legal.editor.name}.
          Toute reproduction, représentation, modification ou exploitation non autorisée est interdite
          sans accord écrit préalable des titulaires des droits concernés.
        </p>
        <p>
          Toute exploitation non autorisée pourra faire l'objet de poursuites conformément aux
          dispositions des articles L.335-2 et suivants du Code de la propriété intellectuelle.
        </p>
      </LegalSection>

      <LegalSection title="6. Crédits photographiques">
        <p>
          Les photographies illustrant le site sont des images libres de droits issues de{' '}
          <a href="https://unsplash.com" class="text-terracotta hover:underline" target="_blank" rel="noopener noreferrer">Unsplash</a>,
          utilisées conformément à la licence Unsplash.
        </p>
        <ul class="space-y-2">
          {
            imageCredits.map((image) => (
              <li>
                Photo par{' '}
                <a href={image.credit.url} class="text-terracotta hover:underline" target="_blank" rel="noopener noreferrer">
                  {image.credit.name}
                </a>{' '}
                sur Unsplash
              </li>
            ))
          }
        </ul>
      </LegalSection>

      <LegalSection title="7. Données personnelles (RGPD)">
        <p>
          Conformément au Règlement Général sur la Protection des Données (RGPD) et à la loi
          « Informatique et Libertés », vous disposez d'un droit d'accès, de rectification,
          d'effacement, de limitation, d'opposition et de portabilité concernant vos données
          personnelles.
        </p>

        <h3 class="font-semibold text-charcoal mt-6 mb-2">Responsable du traitement</h3>
        <p>
          Les données transmises via le formulaire de contact ou par email dans le cadre d'une
          demande de prestation sont traitées par {legal.professional.name} ({site.email}).
        </p>

        <h3 class="font-semibold text-charcoal mt-6 mb-2">Données collectées</h3>
        <p>
          Nom, adresse email, contenu du message et, le cas échéant, numéro de téléphone,
          transmis volontairement par l'utilisateur.
        </p>

        <h3 class="font-semibold text-charcoal mt-6 mb-2">Finalité du traitement</h3>
        <p>
          Répondre à vos demandes de renseignements, organiser un premier échange ou établir un devis.
          Les données ne sont ni vendues, ni cédées à des tiers.
        </p>

        <h3 class="font-semibold text-charcoal mt-6 mb-2">Durée de conservation</h3>
        <p>
          Vos données sont conservées pendant la durée nécessaire au traitement de votre demande,
          puis archivées ou supprimées conformément aux obligations légales applicables.
        </p>

        <h3 class="font-semibold text-charcoal mt-6 mb-2">Exercer vos droits</h3>
        <p>
          Contactez {legal.professional.name} à{' '}
          <a href={site.emailHref} class="text-terracotta hover:underline">{site.email}</a>.
          Pour toute question relative au fonctionnement technique du site, contactez{' '}
          <a href={legal.editor.emailHref} class="text-terracotta hover:underline">{legal.editor.email}</a>.
          Vous pouvez également introduire une réclamation auprès de la CNIL (
          <a href="https://www.cnil.fr" class="text-terracotta hover:underline" target="_blank" rel="noopener noreferrer">www.cnil.fr</a>).
        </p>
      </LegalSection>

      <LegalSection title="8. Cookies">
        <p>
          Ce site ne dépose pas de cookies de mesure d'audience ou de publicité. Seuls des cookies
          techniques strictement nécessaires au fonctionnement du site peuvent être utilisés le cas
          échéant par l'hébergeur.
        </p>
      </LegalSection>

      <LegalSection title="9. Limitation de responsabilité">
        <p>
          {legal.editor.name} et {legal.professional.name} s'efforcent d'assurer l'exactitude des
          informations diffusées sur ce site, sans toutefois en garantir l'exhaustivité ou l'actualité.
        </p>
        <p>
          Les informations présentes ne constituent pas un engagement contractuel. Seul un devis ou
          une convention signée entre les parties fait foi.
        </p>
      </LegalSection>

      <LegalSection title="10. Sécurité du site">
        <p>
          {legal.editor.name} met en œuvre des mesures de sécurité renforcées pour protéger les
          visiteurs : chiffrement HTTPS (HSTS), politique de sécurité du contenu (CSP), protection
          contre le clickjacking, restrictions des autorisations navigateur, et ressources servies
          exclusivement depuis le site (polices et images auto-hébergées).
        </p>
        <p>
          Le formulaire de contact intègre une validation des données, un filtre anti-spam (honeypot)
          et une limitation de fréquence d&apos;envoi côté navigateur.
        </p>
        <p>
          Pour signaler une vulnérabilité :{' '}
          <a href={legal.editor.emailHref} class="text-terracotta hover:underline">{legal.editor.email}</a>{' '}
          ou consultez{' '}
          <a href="/.well-known/security.txt" class="text-terracotta hover:underline">security.txt</a>.
        </p>
      </LegalSection>

      <LegalSection title="11. Droit applicable">
        <p>
          Les présentes mentions légales sont régies par le droit français. En cas de litige,
          et à défaut de résolution amiable, les tribunaux français seront seuls compétents.
        </p>
      </LegalSection>

      <p class="text-sm text-charcoal-light/70 pt-4 border-t border-cream-dark">
        Dernière mise à jour : {new Date().toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}.
      </p>
    </div>
  </section>
</BaseLayout>

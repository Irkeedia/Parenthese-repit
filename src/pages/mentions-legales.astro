---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import LegalSection from '../components/LegalSection.astro';
import { site } from '../data/site';

const { legal } = site;
---

<BaseLayout
  title="Mentions légales — Parenthèse Répit"
  description="Mentions légales, propriété intellectuelle et protection des données personnelles du site Parenthèse Répit."
  currentPath="/mentions-legales"
>
  <PageHeader
    title="Mentions légales"
    subtitle="Conformes LCEN (loi n° 2004-575 du 21 juin 2004) et RGPD."
  />

  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <p class="text-sm text-charcoal-light mb-10">
        Conformément aux dispositions des articles 6-III et 19 de la loi n° 2004-575 du 21 juin 2004
        pour la confiance dans l'économie numérique (LCEN), les présentes mentions légales sont
        portées à la connaissance des utilisateurs du site {site.name}, accessible à l'adresse{' '}
        <a href={legal.siteUrl} class="text-terracotta hover:underline" target="_blank" rel="noopener noreferrer">{legal.siteUrl}</a>.
      </p>

      <LegalSection title="1. Éditeur du site">
        <ul class="list-none space-y-1 pl-0">
          <li><strong class="text-charcoal">{legal.editor.name}</strong></li>
          <li>{legal.editor.status}</li>
          <li>{legal.editor.activity}</li>
          <li>
            Email :{' '}
            <a href={site.emailHref} class="text-terracotta hover:underline">{site.email}</a>
          </li>
          <li>
            Téléphone :{' '}
            <a href={site.phoneHref} class="text-terracotta hover:underline">{site.phone}</a>
          </li>
        </ul>
        <p class="mt-4">
          Directrice de la publication : <strong class="text-charcoal">{legal.publicationDirector}</strong>
        </p>
      </LegalSection>

      <LegalSection title="2. Développement">
        <p>Site conçu et développé par :</p>
        <ul class="list-none space-y-1 pl-0 mt-4">
          <li>
            <strong class="text-charcoal">{legal.developer.name}</strong> — {legal.developer.manager}
          </li>
          <li>
            Site :{' '}
            <a href={legal.developer.website} class="text-terracotta hover:underline" target="_blank" rel="noopener noreferrer">
              irkeedia.com
            </a>
          </li>
          <li>
            Email :{' '}
            <a href={legal.developer.emailHref} class="text-terracotta hover:underline">{legal.developer.email}</a>
          </li>
        </ul>
      </LegalSection>

      <LegalSection title="3. Hébergement">
        <ul class="list-none space-y-1 pl-0">
          <li><strong class="text-charcoal">{legal.host.name}</strong></li>
          <li>{legal.host.address}</li>
          <li>
            Site :{' '}
            <a href={legal.host.website} class="text-terracotta hover:underline" target="_blank" rel="noopener noreferrer">
              vercel.com
            </a>
          </li>
        </ul>
      </LegalSection>

      <LegalSection title="4. Propriété intellectuelle">
        <p>
          L'ensemble du contenu de ce site (textes, visuels, structure) est la propriété exclusive
          de {legal.editor.name} et de {legal.developer.name}.
        </p>
        <p>
          Toute reproduction, même partielle, est interdite sans autorisation préalable écrite.
        </p>
      </LegalSection>

      <LegalSection title="5. Données personnelles et RGPD">
        <p>
          Ce site ne collecte aucune donnée personnelle automatiquement. Aucun cookie de tracking,
          aucun outil de statistiques tiers.
        </p>
        <p>
          Le formulaire de contact fonctionne via votre client de messagerie (mailto:) : aucune
          donnée n'est transmise à un serveur tiers. Les informations que vous communiquez
          volontairement (nom, message) sont utilisées uniquement pour répondre à votre demande
          et ne sont pas conservées au-delà de cet usage.
        </p>
        <p>
          Conformément au RGPD (Règlement UE 2016/679) et à la loi Informatique et Libertés,
          vous disposez d'un droit d'accès, de rectification et de suppression de vos données.
        </p>
        <p>
          Contact :{' '}
          <a href={site.emailHref} class="text-terracotta hover:underline">{site.email}</a>
        </p>
      </LegalSection>

      <LegalSection title="6. Responsabilité">
        <p>
          {legal.editor.name} s'efforce de maintenir les informations de ce site à jour. Elle ne
          saurait être tenue responsable des erreurs ou omissions, ni des dommages résultant de
          l'utilisation des informations publiées.
        </p>
      </LegalSection>

      <LegalSection title="7. Liens externes">
        <p>
          Ce site peut contenir des liens vers des sites tiers. {legal.editor.name} n'est pas
          responsable du contenu de ces sites.
        </p>
      </LegalSection>

      <p class="text-sm text-charcoal-light/70 pt-4 border-t border-cream-dark">
        Dernière mise à jour : {new Date().toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}.
      </p>
    </div>
  </section>
</BaseLayout>

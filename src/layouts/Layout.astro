---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Parenthèse Répit — Accompagnement bienveillant à domicile',
  description = 'Accompagnement éducatif et social à domicile entre Narbonne et Béziers. Répit parental, accompagnement TSA et handicap, aide ponctuelle ou quotidienne.',
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="color-scheme" content="light" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
